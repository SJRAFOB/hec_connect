rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Médias du chat (images, vidéos, audio) ──────────
    // Seul l'utilisateur propriétaire peut uploader dans son dossier
    // Tous les utilisateurs connectés peuvent lire (pour afficher les médias dans le chat)
    match /chat_media/{userId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   // Taille max : 20 Mo
                   && request.resource.size <= 20 * 1024 * 1024
                   // Types autorisés : images, vidéos, audio
                   && (request.resource.contentType.matches('image/.*')
                    || request.resource.contentType.matches('video/.*')
                    || request.resource.contentType.matches('audio/.*'));
    }

    // ── Photos de profil ─────────────────────────────────
    match /profile_photos/{userId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Fichiers joints aux annonces ─────────────────────
    // Le chemin inclut l'UID de l'uploader : seul lui peut écrire son dossier.
    // La restriction de rôle (admin/staff) est garantie par la règle Firestore
    // qui empêche la création d'un doc annonce sans ce rôle.
    match /announcements/{userId}/{fileName} {
      allow read:  if request.auth != nu